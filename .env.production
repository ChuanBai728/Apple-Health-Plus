# ============================================
# Apple Health+ 生产环境变量
# 复制此文件为 .env 并填入实际值
# ============================================

# 域名 (必填)
DOMAIN=health.your-domain.com

# PostgreSQL (必填 — 修改密码)
DB_PASSWORD=your-secure-db-password

# DeepSeek AI API Key (必填)
DEEPSEEK_API_KEY=sk-your-key

# 存储类型: local 或 s3
STORAGE_TYPE=local

# MinIO (使用 S3 存储时必填)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# 邮箱 (Let's Encrypt 证书通知)
CERT_EMAIL=your-email@example.com
